        private void ShutDownDrobitCallback(object obj)
        {
            if (obj == null)
                return;

            KeyValuePair<string, DrobitEq> pair = (KeyValuePair<string, DrobitEq>)obj;
            DrobitEq d = pair.Value;

            HMIMessageBase m = HMIMessageBaseFactory.createMessage();
            m.Type = HMIMessageBase.TYPE.CMD;
            m.Subtype = HMIMessageBase.SUBTYPE.CMD_DROBIT_SHUTDOWN;
            m.DST_ID = d.Serial;

            tcpCommunicator.send(d.Serial, m.serialize());
        }
        #endregion

        private void RefreshRemoteRecordings(object obj)
        {
            if (obj == null)
                return;

            DrobitEq d = (DrobitEq)obj;

            d.RemoteRecordingList.Clear();

            HMIMessageBase m = HMIMessageBaseFactory.createMessage();
            m.Type = HMIMessageBase.TYPE.CMD;
            m.Subtype = HMIMessageBase.SUBTYPE.CMD_REQ_REMOTEPROJECTS;
            m.DST_ID = d.Serial;

            tcpCommunicator.send(d.Serial, m.serialize());
        }

