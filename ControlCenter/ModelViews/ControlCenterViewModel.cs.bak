        public void SaveConfigAction(object parameter)
        {
            DrobitEq selectedEQ = (DrobitEq)parameter;

            // Commands and send
            HMIMessageBase message = HMIMessageBaseFactory.createMessage();
            message.DST_ID = selectedEQ.Serial;
            message.Type = HMIMessageBase.TYPE.CMD;
            message.Subtype = HMIMessageBase.SUBTYPE.CMD_SET_PARAM_BY_NAME;

            Dictionary<string, string> param = new Dictionary<string, string>();

            if (ConfControl.TB_Name.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.S_NAME, ConfControl.TB_Name.Text);
            if (ConfControl.C_Role.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.S_ROLE, ConfControl.C_Role.SelectedValue.ToString());

            if (ConfControl.CB_RecBoot.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.B_RECONBOOT, ConfControl.CB_RecBoot.IsChecked.ToString());
            if (ConfControl.C_TriggerINType.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.S_INPUT_TRIGGERTYPE, ConfControl.C_TriggerINType.SelectedValue.ToString());
            if (ConfControl.C_RecPath.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.S_REC_PATH, ConfControl.C_RecPath.SelectedValue.ToString());

            if (ConfControl.TB_CamXOffB.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_CAM_OFFSET_XB, ConfControl.TB_CamXOffB.Text);
            if (ConfControl.TB_CamYOffB.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_CAM_OFFSET_YB, ConfControl.TB_CamYOffB.Text);
            if (ConfControl.TB_CamZOffB.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_CAM_OFFSET_ZB, ConfControl.TB_CamZOffB.Text);

            if (ConfControl.TB_CamXOffH.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_CAM_OFFSET_XH, ConfControl.TB_CamXOffH.Text);
            if (ConfControl.TB_CamYOffH.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_CAM_OFFSET_YH, ConfControl.TB_CamYOffH.Text);
            if (ConfControl.TB_CamZOffH.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_CAM_OFFSET_ZH, ConfControl.TB_CamZOffH.Text);

            if (ConfControl.M11B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M11B, ConfControl.M11B.Text);
            if (ConfControl.M12B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M12B, ConfControl.M12B.Text);
            if (ConfControl.M13B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M13B, ConfControl.M13B.Text);
            if (ConfControl.M21B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M21B, ConfControl.M21B.Text);
            if (ConfControl.M22B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M22B, ConfControl.M22B.Text);
            if (ConfControl.M23B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M23B, ConfControl.M23B.Text);
            if (ConfControl.M31B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M31B, ConfControl.M31B.Text);
            if (ConfControl.M32B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M32B, ConfControl.M32B.Text);
            if (ConfControl.M33B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M33B, ConfControl.M33B.Text);

            if (ConfControl.C1B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_BIAS_XB, ConfControl.C1B.Text);
            if (ConfControl.C2B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_BIAS_YB, ConfControl.C2B.Text);
            if (ConfControl.C3B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_BIAS_ZB, ConfControl.C3B.Text);

            if (ConfControl.TB_A1B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_ACC_BIAS_XB, ConfControl.TB_A1B.Text);
            if (ConfControl.TB_A2B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_ACC_BIAS_YB, ConfControl.TB_A2B.Text);
            if (ConfControl.TB_A3B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_ACC_BIAS_ZB, ConfControl.TB_A3B.Text);

            if (ConfControl.TB_G1B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_GYRO_BIAS_XB, ConfControl.TB_G1B.Text);
            if (ConfControl.TB_G2B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_GYRO_BIAS_YB, ConfControl.TB_G2B.Text);
            if (ConfControl.TB_G3B.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_GYRO_BIAS_ZB, ConfControl.TB_G3B.Text);

            if (ConfControl.M11H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M11H, ConfControl.M11H.Text);
            if (ConfControl.M12H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M12H, ConfControl.M12H.Text);
            if (ConfControl.M13H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M13H, ConfControl.M13H.Text);
            if (ConfControl.M21H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M21H, ConfControl.M21H.Text);
            if (ConfControl.M22H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M22H, ConfControl.M22H.Text);
            if (ConfControl.M23H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M23H, ConfControl.M23H.Text);
            if (ConfControl.M31H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M31H, ConfControl.M31H.Text);
            if (ConfControl.M32H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M32H, ConfControl.M32H.Text);
            if (ConfControl.M33H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_ELLIP_M33H, ConfControl.M33H.Text);

            if (ConfControl.C1H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_BIAS_XH, ConfControl.C1H.Text);
            if (ConfControl.C2H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_BIAS_YH, ConfControl.C2H.Text);
            if (ConfControl.C3H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_MAG_BIAS_ZH, ConfControl.C3H.Text);

            if (ConfControl.TB_A1H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_ACC_BIAS_XH, ConfControl.TB_A1H.Text);
            if (ConfControl.TB_A2H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_ACC_BIAS_YH, ConfControl.TB_A2H.Text);
            if (ConfControl.TB_A3H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_ACC_BIAS_ZH, ConfControl.TB_A3H.Text);

            if (ConfControl.TB_G1H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_GYRO_BIAS_XH, ConfControl.TB_G1H.Text);
            if (ConfControl.TB_G2H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_GYRO_BIAS_YH, ConfControl.TB_G2H.Text);
            if (ConfControl.TB_G3H.Tag.ToString().Equals("1")) param.Add(Configuration.ParametersNames.F_GYRO_BIAS_ZH, ConfControl.TB_G3H.Text);


            MessageExtraDataKeyValueMap extraData = new MessageExtraDataKeyValueMap();
            extraData.map = param;

            message.setExtraDataObject(extraData);

            tcpCommunicator.send(selectedEQ.Serial,message.serialize());

        }

        public void setMap(GMAPUC map)
        {
            this.MapC = map;
        }

        public void setConfigControl(ConfigControl control)
        {
            this.ConfControl = control;
        }

