<UserControl x:Class="ControlCenter.UserControls.PostProcessingControls.DrobitInputFileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlCenter.UserControls.PostProcessingControls"
             xmlns:timeline="clr-namespace:WExtraControlLibrary.UserControls.TimeLine;assembly=WExtraControlLibrary"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:gnssparam="clr-namespace:ControlCenter.Models.JOBS.Parameters.GNSS"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="300">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <materialDesign:Badged x:Name="BA_DropButtom" Grid.Column="0" Grid.Row="0" MinHeight="50" MaxHeight="80" MaxWidth="150" MinWidth="80" Margin="5,15,5,5"
                               BadgeColorZoneMode="PrimaryDark" BadgePlacementMode="Top" Badge="{Binding Type}">
            <Button x:Name="B_Drop" DragEnter="Button_DragEnter" DragLeave="Button_DragLeave"  Drop="Button_Drop" AllowDrop="True" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" Click="Button_Click">
                <StackPanel>
                    <TextBlock x:Name="TB_DropButtom" TextWrapping="Wrap" TextAlignment="Center" FontSize="11" Text="{Binding Name}"/>
                </StackPanel>
            </Button>
        </materialDesign:Badged>
        <timeline:TimeLineControl x:Name="timeLineControl" Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Grid.RowSpan="2"/>
    </Grid>
</UserControl>
