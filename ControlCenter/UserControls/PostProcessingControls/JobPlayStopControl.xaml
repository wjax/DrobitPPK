<UserControl x:Class="ControlCenter.UserControls.PostProcessingControls.JobPlayStopControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlCenter.UserControls.PostProcessingControls"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:circProgress="clr-namespace:WExtraControlLibrary.UserControls.CircularProgressBar;assembly=WExtraControlLibrary"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="300">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Button Grid.Column="0" Style="{StaticResource MaterialDesignFloatingActionLightButton}"  VerticalAlignment="Center" HorizontalAlignment="Center"
                Content="{materialDesign:PackIcon Stop}"
                Margin="10"
                Command="{Binding StopCommand}"
                Width="32" Height="32"
                CommandParameter="{Binding ElementName=DragablzItemsControl}"/>
        <Button Grid.Column="1" Style="{StaticResource MaterialDesignFloatingActionLightButton}"  VerticalAlignment="Center" HorizontalAlignment="Center"
                Content="{materialDesign:PackIcon Play}"
                Margin="10"
                Command="{Binding StartCommand}"
                Width="48" Height="48"
                CommandParameter="{Binding ElementName=DragablzItemsControl}"/>
        <StackPanel Orientation="Vertical" Grid.Column="2" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding Phase}"  HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding Percentage}" IsEnabled="False" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0" FontSize="10"/>
        </StackPanel>
        <ProgressBar Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" Value="{Binding Percentage}" Minimum="0" Maximum="100" materialDesign:TransitionAssist.DisableTransitions="True" Margin="0,0,0,2"></ProgressBar>
    </Grid>
</UserControl>
